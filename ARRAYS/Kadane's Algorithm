class Solution {
  public:
    int maxSubarraySum(vector<int> &arr) {
        // Code here
        int res = arr[0];
        
        int maxSum = arr[0];
        
        for(int i =1;i<arr.size();i++){
            maxSum = max(arr[i],maxSum + arr[i]);
             res =max(res,maxSum);
             
          
        }
          return res;
    }
};