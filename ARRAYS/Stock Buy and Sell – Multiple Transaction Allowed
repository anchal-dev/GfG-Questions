class Solution {
public:
    int maxProfit(vector<int> &arr) {
        int n = arr.size();
        int res = 0;
        int i = 0;

        while(i < n-1) {

            while(i < n-1 && arr[i] >= arr[i+1])
                i++;

            if(i == n-1) break;

            int lmin = arr[i];

            while(i < n-1 && arr[i] <= arr[i+1])
                i++;

            int lmax = arr[i];

            res += (lmax - lmin);
        }

        return res;
    }
};