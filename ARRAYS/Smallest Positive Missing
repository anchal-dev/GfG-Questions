class Solution {
  public:
    int missingNumber(vector<int> &arr) {
        // code here
        int n =arr.size();
         int missing = 1;
        sort(arr.begin(),arr.end());
       
        for(int i =0;i<n;i++){
           
             if(arr[i]==missing){
                 missing++;
             }
             else if(arr[i]>missing)
             
                break;
             
        }
        return missing;
    }
};