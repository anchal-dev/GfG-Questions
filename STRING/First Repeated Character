class Solution {
  public:
    string firstRepChar(string s) {
        // code here.
        int n =s.size();
        for(int i =0;i<n;i++){
            for(int j=0;j<i;j++){
                if(s[i] == s[j]){
                  string result = "";
                  result += s[i];  
                  return result;
                }
                
            }
        }
        
        return "-1";
    }
};