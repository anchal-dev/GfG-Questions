class Solution {
  public:
    int longestUniqueSubstr(string &s) {
        // code here
        int n = s.size();
       int count =0;
        for(int i=0;i<n;i++){
          vector<bool>vis(26,false);
          for(int j =i;j<n;j++){
              if(vis[s[j]- 'a']== true)
              break;
              else{
                  count =max(count,j-i+1);
                  vis[s[j] - 'a'] = true;
              }
          }
        }
        return count;
    }
};
