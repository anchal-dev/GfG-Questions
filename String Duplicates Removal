// User function template for C++
class Solution {
  public:
    string removeDuplicates(string &s) {
        // code here
        vector<int>ch(256,0);
        string  ans = "";
           for(char c :s){
               if(ch [c] == 0){
                   ans.push_back(c);
                   ch[c]++;
                   
               }
           }
           return ans;
    }
};